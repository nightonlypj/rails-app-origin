<h2><%= @customer.name %>のメンバー権限変更</h2>

<%= form_with(model: @customer_user, url: customer_user_path(customer_code: @customer.code, user_code: @customer_user.user.code), local: true) do |form| %>
  <%= render 'users/shared/error_messages', resource: @customer_user %>

  <div class="field">
    <%= form.label '表示名' %>
    <%= image_tag @customer_user.user.image_url(:small) %> <%= @customer_user.user.name %>
  </div>

  <div class="field">
    <%= form.label 'メールアドレス' %>
    <%= @customer_user.user.email %>
  </div>

  <div class="field">
    <%= form.label '権限' %>
    <% CustomerUser.powers.each do |power| %>
      <%= form.radio_button :power, power[0] %> <%= CustomerUser.powers_i18n[power[0]] %>
    <% end %>
    <%= render 'users/shared/field_error_messages', messages: @customer_user.errors[:power] %>
  </div>

  <div class="actions">
    <%= form.submit '変更' %>
  </div>
<% end %>

<ul>
  <li><%= link_to 'メンバー一覧', customer_users_path(customer_code: @customer.code) %></li>
</ul>
