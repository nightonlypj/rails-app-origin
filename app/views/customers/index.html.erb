<h2>所属一覧</h2>

<% if @customers.blank? %>
所属先がありません。
<% else %>
<% if @customers.total_count > @customers.limit_value %>
<p><%= page_entries_info @customers %></p>
<% end %>
<p><%= paginate @customers %></p>
<table>
  <thead>
    <tr>
      <th>顧客コード</th>
      <th>顧客名</th>
      <th>あなたの権限</th>
      <th>メンバー</th>
    </tr>
  </thead>
  <tbody>
<% @customers.each do |customer| %>
    <tr>
      <td><%= customer.code %></td>
      <td><%= customer.name %></td>
      <td>
<% customer.member.each do |member| %>
      <%= member.power_i18n %><br/>
<% end %>
      </td>
      <td><%= link_to '一覧', members_path(customer.code) %></td>
    </tr>
<% end %>
  </tbody>
</table>
<p><%= paginate @customers %></p>
<% end %>
