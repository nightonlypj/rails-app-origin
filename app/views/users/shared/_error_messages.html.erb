<% if resource.errors.any? || ((defined? resource2) && resource2.errors.any?) %>
<aside>
  <p class="note note-danger m-1"><%= I18n.t('errors.messages.not_saved', count: resource.errors.count + ((defined? resource2) ? resource2.errors.count : 0), resource: resource.class.model_name.human.downcase) %></p>
  <%= "<!-- #{resource.errors.full_messages} -->".html_safe if resource.errors.any? %>
  <%= "<!-- #{resource2.errors.full_messages} -->".html_safe if (defined? resource2) && resource2.errors.any? %>
</aside>
<% end %>
