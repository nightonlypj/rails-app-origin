<main class="container mb-1">
  <div class="row mb-2">
    <div class="col-sm-11">
      <ul class="nav nav-tabs">
        <li class="nav-item text-nowrap"><div class="nav-link active">参加スペース</div></li>
        <li class="nav-item text-nowrap"><%= link_to '公開スペース', public_spaces_path, class: 'nav-link' %></li>
      </ul>
    </div>
    <div class="col-sm-1">
      <div class="float-end text-nowrap mt-2"><%= link_to 'スペース作成', new_space_path, class: 'btn btn-outline-dark btn-rounded btn-sm' %></div>
    </div>
  </div>

<% if @spaces.present? %>
  <div class="row bg-light m-0">
    <div class="col-sm-5 d-flex align-items-center">
      <%= page_entries_info @spaces %>
    </div>
    <div class="col-sm-7">
      <div class="float-sm-end"><%= paginate @spaces %></div>
    </div>
  </div>
<% end %>

  <div class="table-responsive">
    <table class="table table-sm align-middle mb-2">
      <thead>
        <tr>
          <th scope="col" nowrap>スペース名 <wbr>(サブドメイン)</th>
          <th scope="col" nowrap>組織・団体名 <wbr>(顧客コード)</th>
          <th scope="col" nowrap>作成日▼</th>
        </tr>
      </thead>
      <tbody>
<% if @spaces.blank? %>
        <tr>
          <td scope="row" colspan="3" class="text-center">参加スペースがありません。</td>
        </tr>
<% end %>
<% @spaces.each do |space| %>
        <tr>
          <td scope="row" nowrap>
            <%= link_to (image_tag space.image_url(:small)).html_safe + ' ' + space.name, "//#{space.subdomain}.#{Settings['base_domain']}" %>
            <wbr>(<%= space.subdomain %>) <%= public_icon_tag(space.public_flag).html_safe %>
          </td>
          <td nowrap>
            <%= link_to space.customer.name, customer_path(space.customer.code) %>
            <wbr>(<%= space.customer.code %>)
          </td>
          <td nowrap>
            <%= l(space.created_at.to_date) %>
<% if space.customer.member.first.space_update_power? %>
            <wbr><%= link_to '変更', "//#{space.subdomain}.#{Settings['base_domain']}#{edit_space_path}", class: 'btn btn-outline-warning btn-rounded btn-sm float-end' %>
<% end %>
          </td>
        </tr>
<% end %>
      </tbody>
    </table>
  </div>

<% if @spaces.total_pages > 1 %>
  <div class="row m-0">
    <div class="col">
      <div class="float-sm-end"><%= paginate @spaces %></div>
    </div>
  </div>
<% end %>
</main>
