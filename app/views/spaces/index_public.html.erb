<main class="container">
  <h3 class="pt-3">スペース一覧</h3>

  <ul class="nav nav-tabs mb-4">
    <li class="nav-item"><%= link_to '参加スペース', spaces_path, class: 'nav-link' %></li>
    <li class="nav-item"><div class="nav-link active">公開スペース</div></li>
  </ul>

  <div class="row">
    <div class="col">
      <div class="float-end"><%= link_to 'スペース作成', new_space_path, class: 'btn btn-dark btn-rounded mb-1' %></div>
    </div>
  </div>

<% if @spaces.present? %>
  <div class="row">
    <div class="col-sm-5 d-flex align-items-center">
      <%= page_entries_info @spaces %>
    </div>
    <div class="col-sm-7">
      <div class="float-sm-end"><%= paginate @spaces %></div>
    </div>
  </div>
<% end %>

  <div class="table-responsive">
    <table class="table table-sm align-middle">
      <thead>
        <tr>
          <th scope="col" nowrap>スペース名 <wbr>(サブドメイン)</th>
          <th scope="col" nowrap>作成日▼</th>
        </tr>
      </thead>
      <tbody>
<% if @spaces.blank? %>
        <tr>
          <td scope="row" colspan="2" class="text-center">公開スペースがありません。</td>
        </tr>
<% end %>
<% @spaces.each do |space| %>
        <tr>
          <td nowrap>
            <%= link_to (image_tag space.image_url(:small)).html_safe + ' ' + space.name, "//#{space.subdomain}.#{Settings['base_domain']}" %>
            <wbr>(<%= space.subdomain %>) <%= public_icon_tag(space.public_flag).html_safe %>
          </td>
          <td nowrap><%= l(space.created_at.to_date) %></td>
        </tr>
<% end %>
      </tbody>
    </table>
  </div>

  <div class="row">
    <div class="col">
      <div class="float-sm-end"><%= paginate @spaces %></div>
    </div>
  </div>
</main>
