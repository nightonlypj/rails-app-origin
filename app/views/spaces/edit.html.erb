<%= render 'users/shared/error_messages', resource: @space %>

<main class="card mb-1" style="max-width: 850px; margin-left: auto; margin-right: auto">
  <div class="card-body">
    <div class="row">
      <div class="col">
        <h5 class="card-title">スペース情報変更</h5>
      </div>
    </div>
    <div class="row">
      <div class="col-md-4">
        <%= render 'edit_image' %>
      </div>
      <div class="col-md-8">
        <%= render 'edit_space' %>
      </div>
    </div>
    <p class="card-footer"><%= render 'links' %></p>
  </div>
</main>
