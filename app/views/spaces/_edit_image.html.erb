<% validate_enabled = action_name == 'image_update' && @space.errors.any? %>
<%= form_for(@space, as: @space_name, url: update_space_image_path, html: { method: :put, novalidate: true, id: 'edit_image' }, local: true) do |form| %>
  <div>
    <%= image_tag @request_space.image_url(:xlarge) %>
  </div>

  <div class="form-outline<%= input_size_class_name(@space, :image) %>">
    <%= form.file_field :image, class: "form-control#{validate_class_name(validate_enabled, @space, :image)}" %>
    <%= render 'users/shared/field_error_messages', messages: @space.errors[:image] %>
  </div>

  <%= form.submit 'アップロード', class: "btn btn-primary #{@request_space.image? ? 'mb-3' : 'mb-4'}" %>
<% end %>
<% if @request_space.image? %>
  <%= button_to '画像削除', delete_space_image_path, data: { confirm: '本当に削除しますか？' }, method: :delete, class: 'btn btn-warning mb-4' %>
<% end %>
