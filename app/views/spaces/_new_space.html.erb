<% validate_enabled = @space.errors.any? || @customer.errors.any? %>
<%= form_with(model: @space, html: { novalidate: true }, local: true) do |form| %>

<%= form.fields_for @customer do |form_customer| %>
  <div class="<%= input_size_class_name(@customer, :code) %>"><%# selectはFree版未対応？(form-outlineを入れると崩れる) %>
    <%= form_customer.label '顧客名 (コード)', class: "form-label small#{validate_text_class_name(validate_enabled, @customer, :code)}", for: 'space_customer_code' %>
    <%= form_customer.select :code, @customers.all.collect { |customer| [ "#{customer.name} (#{customer.code})", customer.code ] }, { include_blank: true }, class: "form-control#{validate_class_name(validate_enabled, @customer, :code)}" %>
    <%= render 'users/shared/field_error_messages', messages: @customer.errors[:code] %>
  </div>
<% end %>

  <div class="form-outline<%= input_size_class_name(@space, :subdomain) %>">
    <%= form.text_field :subdomain, autocomplete: 'name', class: "form-control#{validate_class_name(validate_enabled, @space, :subdomain)}" %>
    <%= form.label 'サブドメイン', class: 'form-label', for: 'space_subdomain' %>
    <%= render 'users/shared/field_error_messages', messages: @space.errors[:subdomain] %>
  </div>

  <div class="form-outline<%= input_size_class_name(@space, :name) %>">
    <%= form.text_field :name, autocomplete: 'name', class: "form-control#{validate_class_name(validate_enabled, @space, :name)}" %>
    <%= form.label 'スペース名', class: 'form-label', for: 'space_name' %>
    <%= render 'users/shared/field_error_messages', messages: @space.errors[:name] %>
  </div>

  <%= form.submit '作成', class: 'btn btn-primary' %>
<% end %>
