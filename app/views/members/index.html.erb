<h2><%= @customer.name %>のメンバー一覧</h2>

<% if @customer.member.first.create_power? %>
<%= link_to '招待', new_member_path(customer_code: @customer.code) %>
<% end %>

<p><%= page_entries_info @members %></p>
<p><%= paginate @members %></p>
<table>
  <thead>
    <tr>
      <th colspan="2">表示名</th>
      <th>メールアドレス</th>
      <% if @customer.member.first.update_power? %>
        <th colspan="2">権限</th>
      <% else %>
        <th>権限</th>
      <% end %>
      <th>招待日</th>
      <% if @customer.member.first.destroy_power? %>
        <th colspan="2">登録日</th>
      <% else %>
        <th>登録日</th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% @members.each do |member| %>
      <tr>
        <td><%= image_tag member.user.image_url(:small) %></td>
        <td><%= member.user.name %></td>
        <td><%= member.user.email %></td>
        <td><%= member.power_i18n %></td>
        <% if @customer.member.first.update_power? %>
          <td><%= link_to '変更', edit_member_path(customer_code: @customer.code, user_code: member.user.code) %></td>
        <% end %>
        <td><%= member.invitationed_at.present? ? l(member.invitationed_at.to_date) : t('blank_word.member.invitationed_at') %></td>
        <td><%= member.registrationed_at.present? ? l(member.registrationed_at.to_date) : t('blank_word.member.registrationed_at') %></td>
        <% if @customer.member.first.destroy_power? %>
          <td><%= link_to '解除', delete_member_path(customer_code: @customer.code, user_code: member.user.code) %></td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>
<p><%= paginate @members %></p>
