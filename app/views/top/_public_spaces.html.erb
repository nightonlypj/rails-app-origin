<article class="card mb-1">
  <div class="card-body">
    <h5 class="card-title"><%= link_to '公開スペース', public_spaces_path, class: 'text-dark' %></h5>
    <ul class="list-group">
<% @public_spaces.each do |public_space| %>
      <li class="list-group-item">
        <%= link_to (image_tag public_space.image_url(:small)).html_safe + ' ' + public_space.name, "//#{public_space.subdomain}.#{Settings['base_domain']}" %>
        <%= public_icon_tag(public_space.public_flag).html_safe %>
      </li>
<% end %>
    </ul>
<% if @public_spaces.total_pages > 1 %>
    <nav>
      <%= link_to 'もっと見る', public_spaces_path, class: 'btn btn-info btn-rounded btn-sm m-2' %>
    </nav>
<% end %>
  </div>
</article>
