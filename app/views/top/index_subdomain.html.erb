<main>
  <div class="p-1 mb-1" style="background-color: #F0F2F5">
    <div class="btn-group">
      <%= link_to (image_tag @request_space.image_url(:small)).html_safe + ' ' + @request_space.name, root_path, class: 'btn btn-white fs-5' %>
      <button type="button" class="btn btn-white dropdown-toggle dropdown-toggle-split" data-mdb-toggle="dropdown" aria-expanded="false">
        <span class="visually-hidden"></span>
      </button>
      <ul class="dropdown-menu">
<% if @join_spaces.present? %>
<% @join_spaces.each do |join_space| %>
        <li><%= link_to (image_tag join_space.image_url(:small)).html_safe + ' ' + join_space.name, "//#{join_space.subdomain}.#{Settings['base_domain']}", class: 'dropdown-item' %></li>
<% end %>
        <li><hr class="dropdown-divider" /></li>
<% if @join_spaces.total_pages > 1 %>
        <li><%= link_to 'もっと見る', "//#{Settings['base_domain']}#{spaces_path}", class: 'dropdown-item' %></li>
<% end %>
<% end %>
        <li><%= link_to '公開スペース一覧', "//#{Settings['base_domain']}#{public_spaces_path}", class: 'dropdown-item' %></li>
      </ul>
    </div>
  </div>
  <div class="container">
    <div class="row">
      <div class="col-sm-6" style="padding-left: 0px; padding-right: 0px">
      </div>
      <div class="col-sm-6" style="padding-left: 0px; padding-right: 0px">
        <%= render 'manage_space' if @member.present? && @member.first.update_power? %>
        <%= render 'infomations' if @infomations.present? %>
      </div>
    </div>
  </div>
</main>
